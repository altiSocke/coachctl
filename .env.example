# Strava credentials (keep secret, never commit)
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here
STRAVA_REFRESH_TOKEN=your_refresh_token_here

# GitHub token — used by SwarmVault to call GitHub Models (gpt-4o-mini, text-embedding-3-small)
# Needs models:read scope. Create at: https://github.com/settings/tokens
# Tip: your existing `gh auth token` output works if it has models:read.
GITHUB_TOKEN=your_github_token_here
