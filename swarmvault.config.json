{
  "providers": {
    "local": {
      "type": "heuristic",
      "model": "heuristic-v1"
    },
    "github-models": {
      "type": "openai-compatible",
      "model": "gpt-4o-mini",
      "baseUrl": "https://models.inference.ai.azure.com",
      "apiKeyEnv": "GITHUB_TOKEN"
    },
    "github-models-embeddings": {
      "type": "openai-compatible",
      "model": "text-embedding-3-small",
      "baseUrl": "https://models.inference.ai.azure.com",
      "apiKeyEnv": "GITHUB_TOKEN"
    }
  },
  "tasks": {
    "compileProvider": "github-models",
    "queryProvider": "github-models",
    "lintProvider": "local",
    "embeddingProvider": "github-models-embeddings",
    "visionProvider": "github-models"
  },
  "profile": {
    "presets": ["reader"],
    "guidedIngestDefault": false,
    "deepLintDefault": false
  },
  "retrieval": {
    "rerank": false
  }
}
